# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_SERVICE_ROLE_KEY — НЕ используйте на клиенте. Только на сервере.

# API (used as fallback for non-Supabase endpoints)
VITE_API_URL=/api
VITE_WS_URL=wss://swiftmatch.example.com

# App
VITE_APP_NAME=SwiftMatch
VITE_APP_VERSION=1.0.0
VITE_IMAGE_BASE_URL=/demo/people
VITE_PAGINATION_LIMIT=20
VITE_CHAT_POLL_INTERVAL=3000
VITE_SESSION_TIMEOUT=3600000

# Monitoring
VITE_SENTRY_DSN=
